{
  "name": "@velocity-bpa/n8n-nodes-notion",
  "version": "1.0.0",
  "description": "n8n node for Notion API integration",
  "license": "bsl-catalog",
  "homepage": "https://docs.n8n.io/integrations/community-nodes/",
  "author": {
    "name": "Velocity BPA",
    "email": "engineering@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-notion.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/NotionApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Notion/Notion.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n-node",
    "notion",
    "workspace",
    "productivity"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "eslint-plugin-n8n-nodes-base": "^1.16.1"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}